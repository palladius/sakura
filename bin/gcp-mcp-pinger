#!/usr/bin/env python3

import sys
import json
import subprocess
import urllib.request
import urllib.error
import textwrap
import shutil
import re

# Color codes 🎨
RESET = "\033[0m"
BOLD_GREEN = "\033[1;32m"
CYAN = "\033[36m"
YELLOW = "\033[33m"
BOLD_BLUE = "\033[1;34m"
BOLD = "\033[1m"

MCP_SERVERS = {
    "alloydb": "https://alloydb.REGION.rep.googleapis.com/mcp",
    "bigquery": "https://bigquery.googleapis.com/mcp",
    "bigquerydatatransfer": "https://bigquerydatatransfer.googleapis.com/mcp",
    "bigquerymigration": "https://bigquerymigration.googleapis.com/mcp",
    "bigtable": "https://bigtableadmin.googleapis.com/mcp",
    "run": "https://run.googleapis.com/mcp",
    "ces": "https://ces.us.rep.googleapis.com/mcp",
    "sqladmin": "https://sqladmin.googleapis.com/mcp",
    "logging": "https://logging.googleapis.com/mcp",
    "monitoring": "https://monitoring.googleapis.com/mcp",
    "compute": "https://compute.googleapis.com/mcp",
    "clouderrorreporting": "https://clouderrorreporting.googleapis.com/mcp",
    "firestore": "https://firestore.googleapis.com/mcp",
    "container": "https://container.googleapis.com/mcp",
    "chronicle": "https://chronicle.REGION.rep.googleapis.com/mcp",
    "managedkafka": "https://managedkafka.REGION.rep.googleapis.com/mcp",
    "pubsub": "https://pubsub.googleapis.com/mcp",
    "cloudresourcemanager": "https://cloudresourcemanager.googleapis.com/mcp",
    "spanner": "https://spanner.googleapis.com/mcp",
    "aiplatform": "https://aiplatform.googleapis.com/mcp",
    "discoveryengine": "https://discoveryengine.googleapis.com/mcp",
    "androidmanagement": "https://androidmanagement.googleapis.com/mcp",
    "developerknowledge": "https://developerknowledge.googleapis.com/mcp",
    "mapstools": "https://mapstools.googleapis.com/mcp",
    "stitch": "https://stitch.googleapis.com/mcp",
}

def get_terminal_width():
    return shutil.get_terminal_size((100, 20)).columns

def print_supported():
    print("🤌 Mamma mia! Here are the supported MCP products (from https://docs.cloud.google.com/mcp/supported-products):")
    print("-" * 106)
    print(f"   {'Product ID':<25} Endpoint (Use 'https://...' for others)")
    print("-" * 106)
    for key in sorted(MCP_SERVERS.keys()):
        print(f"🟢 {key:<25} {MCP_SERVERS[key]}")
    print("\nUsage: gcp-mcp-pinger <product_id|endpoint_url> [tool_name]")

def get_access_token():
    try:
        result = subprocess.run(["gcloud", "auth", "print-access-token"], capture_output=True, text=True, check=True)
        return result.stdout.strip()
    except subprocess.CalledProcessError:
        return None

def fetch_mcp_tools(server_url, token):
    req = urllib.request.Request(server_url, method="POST")
    req.add_header("Content-Type", "application/json")
    req.add_header("Accept", "application/json")
    if token:
        req.add_header("Authorization", f"Bearer {token}")
    
    data = json.dumps({ "method": "tools/list", "jsonrpc": "2.0", "id": 1 }).encode("utf-8")
    
    try:
        with urllib.request.urlopen(req, data=data) as response:
            return json.loads(response.read().decode("utf-8"))
    except urllib.error.URLError as e:
        body = e.read().decode("utf-8") if hasattr(e, 'read') else str(e)
        print(f"❌ MCP Error: {e.reason}\n{body}")
        sys.exit(1)
    except Exception as e:
        print(f"❌ Error: {e}")
        sys.exit(1)

def main():
    if len(sys.argv) < 2:
        print_supported()
        sys.exit(0)

    input_server = sys.argv[1]
    tool_name = sys.argv[2] if len(sys.argv) > 2 else None

    server = input_server
    if not server.startswith("http"):
        server = MCP_SERVERS.get(server, f"https://{server}.googleapis.com/mcp")

    if "REGION" in server:
        server = server.replace("REGION", "us-central1")
        print(f"🤌 No region specified, using default: us-central1")

    print(f"🚀 Pinging MCP Server: {server} ...\n")
    
    token = get_access_token()
    if not token:
        print("⚠️ Warning: No gcloud token found. Request might fail if server requires auth.")

    response = fetch_mcp_tools(server, token)
    
    if "result" not in response or "tools" not in response["result"]:
        print("❌ Error or no tools found. Response:")
        print(json.dumps(response, indent=2))
        sys.exit(1)

    tools = response["result"]["tools"]

    if not tool_name:
        print(f"✅ Success! Found tools in {input_server}:")
        
        name_width = 30
        term_width = get_terminal_width()
        desc_width = max(20, term_width - name_width - 10)

        print(f"   {'TOOL NAME':<{name_width}} DESCRIPTION")
        print("   " + "-" * (term_width - 4))

        for tool in tools:
            name = tool.get("name", "Unknown")
            desc = tool.get("description", "No description provided.").replace("\n", " ")
            desc = re.sub(r'\s+', ' ', desc)

            if len(desc) > desc_width:
                desc = desc[:desc_width-3] + "..."
            
            print(f"🟢 {BOLD_GREEN}{name:<{name_width}}{RESET} {CYAN}{desc}{RESET}")
            
        print(f"\n💡 Tip: Run './gcp-mcp-pinger {input_server} <tool_name>' for the full deep dive!")
        
    else:
        # Detailed view! Beautiful formatting incoming 🎨
        tool = next((t for t in tools if t.get("name") == tool_name), None)
        if not tool:
            print(f"❌ Tool '{tool_name}' not found in {input_server}.")
            sys.exit(1)

        print(f"💎 Tool Details: {BOLD}{tool_name}{RESET}")
        print("=" * 80)
        
        print("📝 Full Description:")
        desc = tool.get("description", "No description provided.")
        for line in textwrap.wrap(desc, width=80):
            print(f"   {CYAN}{line}{RESET}")
        print()
        
        print("📥 Input Schema (Properties):")
        schema = tool.get("inputSchema", {})
        properties = schema.get("properties", {})
        
        if not properties:
            print("   (No input properties defined)")
        else:
            for prop_name, prop_details in properties.items():
                prop_type = prop_details.get("type", "unknown")
                print(f"   🔹 {BOLD_BLUE}{prop_name}{RESET} ({YELLOW}{prop_type}{RESET})")
                
                prop_desc = prop_details.get("description", "No description")
                wrapped_desc = textwrap.wrap(prop_desc, width=76)
                for line in wrapped_desc:
                    print(f"      {line}")
                print()
                
        output_schema = tool.get("outputSchema", {})
        output_type = output_schema.get("type", "unknown")
        print(f"📤 Output Type: {YELLOW}{output_type}{RESET}")

if __name__ == "__main__":
    main()
